# Environment Variables for BUNKR Backend
# Copy this file to .env and fill in your values

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Encryption for vault (must be kept secret!)
ENCRYPTION_KEY=your-32-byte-encryption-key-change-this

# Database
DATABASE_URL=sqlite:///./bunkr.db

# File storage paths
UPLOAD_DIR=./uploads
VAULT_STORAGE_DIR=./vault_storage

# App settings
APP_NAME=BUNKR - Personal Digital Bunker
APP_VERSION=1.0.0
DEBUG=False
